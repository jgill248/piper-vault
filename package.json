{
  "name": "delve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal Knowledge Base & Conversational Search",
  "license": "AGPL-3.0-only",
  "scripts": {
    "build": "nx run-many --target=build",
    "test": "nx run-many --target=test",
    "lint": "nx run-many --target=lint",
    "dev": "nx run-many --target=dev --parallel",
    "dev:api": "nx run @delve/api:dev",
    "dev:web": "nx run @delve/web:dev",
    "db:migrate": "nx run @delve/api:db:migrate",
    "clean": "nx run-many --target=clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["onnxruntime-node", "protobufjs", "sharp"]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "nx": "^22.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.2"
  }
}
