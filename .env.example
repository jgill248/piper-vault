# Delve Environment Variables
# Copy this file to .env and fill in values before starting.
# Never commit .env to source control.

# === Database ===
DATABASE_URL=postgresql://delve:delve@localhost:5432/delve
POSTGRES_USER=delve
POSTGRES_PASSWORD=delve
POSTGRES_DB=delve

# === API Server ===
PORT=3001
NODE_ENV=development

# CORS origin allowed to call the API.
# In production set this to the URL your browser loads Delve from.
CORS_ORIGIN=http://localhost:5173

# === LLM Provider (Ask Sage) ===
ASK_SAGE_API_KEY=
ASK_SAGE_EMAIL=

# === Authentication (Phase 4) ===
# Set AUTH_ENABLED=true to require a username/password login before using Delve.
AUTH_ENABLED=false
# Secret used to sign JWT tokens. MUST be changed in production.
JWT_SECRET=change-me-in-production

# === Plugins (Phase 4) ===
# Absolute path on the host (or in the container) where plugin .js files are placed.
# Leave empty to disable the plugin system.
PLUGINS_DIR=

# === Webhooks (Phase 4) ===
# Maximum number of ingest requests per minute for a single API key.
WEBHOOK_RATE_LIMIT=60

# === Linear (used by Claude Code MCP integration — development only) ===
LINEAR_API_KEY=your-linear-api-key-here
