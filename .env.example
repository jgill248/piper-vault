# Delve Environment Variables
# Copy this file to .env and fill in values before starting.
# Never commit .env to source control.

# === Database ===
DATABASE_URL=postgresql://delve:delve@localhost:5432/delve
POSTGRES_USER=delve
POSTGRES_PASSWORD=delve
POSTGRES_DB=delve

# === API Server ===
PORT=3001
NODE_ENV=development

# === Web UI (Docker Compose) ===
# Port the web UI is exposed on when running via Docker Compose.
WEB_PORT=8080

# CORS origin allowed to call the API.
# In production set this to the URL your browser loads Delve from.
CORS_ORIGIN=http://localhost:5173

# === LLM Providers ===
# Select the active provider in the UI settings or ~/.delve/config.json
# Only the env var for your chosen provider needs to be set.

# Ask Sage (token-based auth — tokens do not expire)
ASK_SAGE_TOKEN=

# Ollama (runs locally — no auth needed)
# Default URL shown below; override only if Ollama runs on a different host/port.
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (direct API access)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# === Authentication (Phase 4) ===
# Set AUTH_ENABLED=true to require a username/password login before using Delve.
AUTH_ENABLED=false
# Secret used to sign JWT tokens. MUST be changed in production.
JWT_SECRET=change-me-in-production

# === Plugins (Phase 4) ===
# Absolute path on the host (or in the container) where plugin .js files are placed.
# Leave empty to disable the plugin system.
PLUGINS_DIR=

# === Webhooks (Phase 4) ===
# Maximum number of ingest requests per minute for a single API key.
WEBHOOK_RATE_LIMIT=60

# === SSL Verification ===
# Set to 0 to bypass SSL certificate verification when downloading the
# embedding model. Required in environments with SSL inspection (corporate
# proxies, some VPNs). The Docker image pre-bakes the model, so this is
# only needed if the cache is cleared or the model is re-downloaded.
NODE_TLS_REJECT_UNAUTHORIZED=0

# === Linear (used by Claude Code MCP integration — development only) ===
LINEAR_API_KEY=your-linear-api-key-here
