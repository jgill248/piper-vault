# Delve Environment Variables

# Database
DATABASE_URL=postgresql://delve:delve@localhost:5432/delve

# Ask Sage API
ASK_SAGE_API_KEY=your-api-key-here
ASK_SAGE_EMAIL=your-email@example.com

# Server
PORT=3001
NODE_ENV=development

# Linear (used by Claude Code MCP integration)
LINEAR_API_KEY=your-linear-api-key-here
